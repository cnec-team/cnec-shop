# === DB (Railway PostgreSQL) ===
DATABASE_URL=                      # Railway PostgreSQL 연결 문자열 (예: postgresql://user:password@host:port/dbname)

# === Payment (PortOne V2) ===
NEXT_PUBLIC_PORTONE_STORE_ID=      # 포트원 상점 ID (클라이언트 결제 위젯용)
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=   # 포트원 채널 키 (결제 PG 채널 선택용)
PORTONE_WEBHOOK_SECRET=            # 포트원 웹훅 서명 검증용 시크릿
PORTONE_API_SECRET=                # 포트원 API 시크릿 (서버 결제 조회/취소용)
PORTONE_V2_API_SECRET=             # 포트원 V2 REST API 시크릿 (본인인증 검증용)
NEXT_PUBLIC_PORTONE_IDENTITY_VERIFICATION_CHANNEL_KEY=  # 포트원 본인인증 채널키 (다날)

# Kakao SDK
NEXT_PUBLIC_KAKAO_JS_KEY=         # 카카오 JavaScript 앱 키 (공유 기능용)

# === Site ===
NEXT_PUBLIC_SITE_URL=             # 사이트 기본 URL (예: https://cnecshop.com)

# === Auth (NextAuth) ===
NEXTAUTH_SECRET=                  # 랜덤 32자 이상 시크릿 (openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000  # 프로덕션에서는 https://cnecshop.com 으로 변경

# === Storage (Cloudflare R2) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# === 무통장입금 (Bank Transfer) ===
BANK_TRANSFER_BANK_NAME=             # 입금 은행명 (예: 국민은행)
BANK_TRANSFER_ACCOUNT_NUMBER=        # 입금 계좌번호 (예: 123-456-789012)
BANK_TRANSFER_ACCOUNT_HOLDER=        # 예금주 (예: (주)크넥)

# === 간편로그인 (카카오) ===
KAKAO_CLIENT_ID=                  # 카카오 OAuth REST API 키
KAKAO_CLIENT_SECRET=              # 카카오 OAuth Client Secret

# === 간편로그인 (네이버) ===
NAVER_CLIENT_ID=                  # 네이버 OAuth Client ID
NAVER_CLIENT_SECRET=              # 네이버 OAuth Client Secret

# === 네이버 쇼핑 API (Price Scout) ===
NAVER_CLIENT_ID=         # 네이버 개발자센터 쇼핑 검색 Client ID
NAVER_CLIENT_SECRET=     # 네이버 개발자센터 쇼핑 검색 Client Secret

# === AI (Claude) ===
ANTHROPIC_API_KEY=                # Anthropic API 키 (AI 공구 어드바이저)

# === Cron ===
CRON_SECRET=                      # Vercel Cron 인증 시크릿

# === Apify (Instagram Sync) ===
APIFY_API_TOKEN=                  # Apify API 토큰
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-profile-scraper

# === Naver Works SMTP (이메일 발송) ===
SMTP_HOST=smtp.worksmobile.com    # SMTP 서버
SMTP_PORT=587                     # SMTP 포트
SMTP_USER=                        # Naver Works 이메일 계정
SMTP_PASSWORD=                    # Naver Works 앱 비밀번호
EMAIL_FROM=                       # 발신자 (예: 크넥샵 <noreply@cnecshop.com>)

# === 팝빌 (카카오 알림톡) ===
POPBILL_LINK_ID=                  # 팝빌 링크 ID
POPBILL_SECRET_KEY=               # 팝빌 시크릿 키
POPBILL_CORP_NUM=                 # 사업자등록번호 (하이픈 제외)
POPBILL_KAKAO_SENDER_KEY=         # 카카오 알림톡 발신프로필 키
POPBILL_IS_TEST=false             # 테스트 모드 (true/false)

# === 브랜드 구독 결제 (토스페이먼츠 개별 API, MID 2) — Phase C ===
NEXT_PUBLIC_TOSS_PAYMENTS_BILLING_CLIENT_KEY=  # 토스 클라이언트 키 (test_ck_ 또는 live_ck_)
TOSS_PAYMENTS_BILLING_SECRET_KEY=              # 토스 시크릿 키 (test_sk_ 또는 live_sk_)
TOSS_PAYMENTS_BILLING_WEBHOOK_SECRET=          # 토스 웹훅 시크릿

# === 결제 공통 ===
PAYMENT_MODE=test                              # test | live
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=http://localhost:3000/ko/brand/billing/success
NEXT_PUBLIC_PAYMENT_FAIL_URL=http://localhost:3000/ko/brand/billing/fail
