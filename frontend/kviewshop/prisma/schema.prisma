// ============================================================
// PROMOTION KITS
// ============================================================

model PromotionKit {
  id                String   @id @default(uuid())
  campaignId        String   @unique @map("campaign_id")
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productImages     String[] @default([]) @map("product_images")
  storyTemplates    String[] @default([]) @map("story_templates")
  recommendedCaption String? @map("recommended_caption")
  hashtags          String[] @default([])

  @@map("promotion_kits")
}

// ============================================================
// BUYERS
// ============================================================

model Buyer {
  id                     String    @id @default(uuid())
  userId                 String    @unique @map("user_id")
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname               String
  profileImage           String?   @map("profile_image")
  phone                  String?
  defaultShippingAddress Json?     @map("default_shipping_address") @db.JsonB
  // Points
  pointsBalance          Int       @default(0) @map("points_balance")
  totalPointsEarned      Int       @default(0) @map("total_points_earned")
  totalPointsUsed        Int       @default(0) @map("total_points_used")
  // Stats
  totalOrders            Int       @default(0) @map("total_orders")
  totalSpent             Decimal   @default(0) @map("total_spent")
  totalReviews           Int       @default(0) @map("total_reviews")
  // Preferences
  preferredLanguage      String    @default("ko") @map("preferred_language")
  preferredCurrency      String    @default("KRW") @map("preferred_currency")
  marketingConsent       Boolean   @default(false) @map("marketing_consent")
  // Creator conversion
  eligibleForCreator     Boolean   @default(false) @map("eligible_for_creator")
  creatorConversionDate  DateTime? @map("creator_conversion_date") @db.Timestamptz
  // Instagram
  instagramUsername      String?   @map("instagram_username")
  instagramVerified      Boolean   @default(false) @map("instagram_verified")
  // Timestamps
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  orders              Order[]
  mallSubscriptions   MallSubscription[]
  communityPosts      CommunityPost[]
  communityComments   CommunityComment[]
  communityLikes      CommunityLike[]
  productQuestions    ProductQuestion[]
  productReviews      ProductReview[]
  reviewHelpfulVotes  ReviewHelpfulVote[]
  pointsHistory       PointsHistory[]
  creatorApplications CreatorApplication[]
  wishlist            BuyerWishlist[]
  cart                BuyerCart[]
  liveChatMessages    LiveChatMessage[]

  @@index([pointsBalance])
  @@index([eligibleForCreator])
  @@map("buyers")
}

// ============================================================
// SAMPLE REQUESTS
// ============================================================

model SampleRequest {
  id              String   @id @default(uuid())
  creatorId       String   @map("creator_id")
  creator         Creator  @relation(fields: [creatorId], references: [id])
  brandId         String   @map("brand_id")
  brand           Brand    @relation(fields: [brandId], references: [id])
  productIds      String[] @default([]) @map("product_ids")
  status          SampleRequestStatus @default(pending)
  shippingAddress Json?    @map("shipping_address") @db.JsonB
  message         String?
  adminNote       String?  @map("admin_note")
  trackingNumber  String?  @map("tracking_number")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Product trial fields
  productId       String?  @map("product_id")
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  decision        SampleRequestDecision?
  rejectReason    String?  @map("reject_reason")
  passReason      String?  @map("pass_reason")
  feedback        String?
  respondedAt     DateTime? @map("responded_at") @db.Timestamptz
  shippedAt       DateTime? @map("shipped_at") @db.Timestamptz
  receivedAt      DateTime? @map("received_at") @db.Timestamptz
  decidedAt       DateTime? @map("decided_at") @db.Timestamptz
  convertedTo     String?  @map("converted_to")
  // 일정 변경 요청
  scheduleChangeRequest  String?  @map("schedule_change_request")
  scheduleChangeBy       String?  @map("schedule_change_by")
  scheduleChangeStatus   String?  @map("schedule_change_status")  // pending, accepted, rejected

  @@index([status])
  @@index([brandId, status])
  @@index([creatorId, status])
  @@map("sample_requests")
}

