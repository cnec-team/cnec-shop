  nextBillingAt         DateTime?          @map("next_billing_at") @db.Timestamptz
  cancelledAt           DateTime?          @map("cancelled_at") @db.Timestamptz
  monthlyFee            Decimal            @default(0) @map("monthly_fee") @db.Decimal(12, 0)
  includedMessageQuota  Int                @default(0) @map("included_message_quota")
  currentMonthUsed      Int                @default(0) @map("current_month_used")
  currentMonthResetAt   DateTime?          @map("current_month_reset_at") @db.Timestamptz
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  payments              SubscriptionPayment[]

  @@index([brandId])
  @@index([expiresAt])
  @@map("brand_subscriptions")
}

// ============================================================
// MESSAGE CREDIT (건별 과금 로그)
// ============================================================

model MessageCredit {
  id                String           @id @default(uuid())
  brandId           String           @map("brand_id")
  brand             Brand            @relation(fields: [brandId], references: [id])
  proposalId        String?          @map("proposal_id")
  type              MessageCreditType
  cost              Decimal          @default(0) @db.Decimal(10, 0)
  pricePerMessage   Decimal          @default(500) @map("price_per_message") @db.Decimal(10, 0)
  attemptedChannels String[]         @default([]) @map("attempted_channels")
  succeededChannels String[]         @default([]) @map("succeeded_channels")
  creatorId         String           @map("creator_id")
  creator           Creator          @relation(fields: [creatorId], references: [id])
  sentAt            DateTime         @default(now()) @map("sent_at") @db.Timestamptz
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz

  proposals         CreatorProposal[]

  @@index([brandId, sentAt])
  @@index([proposalId])
  @@map("message_credits")
}

// ============================================================
// SUBSCRIPTION PAYMENT (구독 결제 내역)
// ============================================================

model SubscriptionPayment {
  id                String            @id @default(uuid())
  brandId           String            @map("brand_id")
  brand             Brand             @relation(fields: [brandId], references: [id])
  subscriptionId    String            @map("subscription_id")
  subscription      BrandSubscription @relation(fields: [subscriptionId], references: [id])
  amount            Decimal           @db.Decimal(12, 0)
  plan              String
  paidAt            DateTime          @default(now()) @map("paid_at") @db.Timestamptz
  portOnePaymentId  String?           @map("portone_payment_id")
  status            SubPaymentStatus  @default(PAID)
  periodStart       DateTime          @map("period_start") @db.Timestamptz
  periodEnd         DateTime          @map("period_end") @db.Timestamptz
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz

  @@index([brandId])
  @@index([subscriptionId])
  @@map("subscription_payments")
}

// ============================================================
// DM SEND QUEUE (크롬 확장용 DM 발송 큐)
// ============================================================

model DmSendQueue {
  id                     String        @id @default(uuid())
  brandId                String        @map("brand_id")
  brand                  Brand         @relation(fields: [brandId], references: [id])
  creatorId              String        @map("creator_id")
  creator                Creator       @relation(fields: [creatorId], references: [id])
  proposalId             String        @map("proposal_id")
  proposal               CreatorProposal @relation(fields: [proposalId], references: [id])
  instagramUsername       String        @map("instagram_username")
  messageBody            String        @map("message_body")
  status                 DmQueueStatus @default(PENDING)
  attemptCount           Int           @default(0) @map("attempt_count")
  lastAttemptedAt        DateTime?     @map("last_attempted_at") @db.Timestamptz
  sentAt                 DateTime?     @map("sent_at") @db.Timestamptz
  failReason             String?       @map("fail_reason")
  brandInstagramAccount  String?       @map("brand_instagram_account")
  priority               Int           @default(0)
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  logs                   DmSendLog[]

  @@index([brandId, status])
  @@index([status, priority])
  @@map("dm_send_queues")
}

// ============================================================
// DM SEND LOG (DM 발송 이벤트 로그)
// ============================================================

model DmSendLog {
  id          String         @id @default(uuid())
  queueId     String         @map("queue_id")
  queue       DmSendQueue    @relation(fields: [queueId], references: [id], onDelete: Cascade)
  event       DmSendLogEvent
  detail      Json?          @db.JsonB
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@index([queueId])
  @@map("dm_send_logs")
}

// ============================================================
// CREATOR FILTER PRESET (브랜드 필터 프리셋)
// ============================================================

model CreatorFilterPreset {
  id        String   @id @default(cuid())
  brandId   String   @map("brand_id")
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  filters   Json     @db.JsonB
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([brandId])
  @@map("creator_filter_presets")
}
