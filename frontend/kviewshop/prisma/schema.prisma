// ============================================================
// USERS
// ============================================================

model User {
  id        String     @id @default(uuid())
  email     String     @unique @db.VarChar(255)
  name      String     @db.VarChar(100)
  passwordHash String? @map("password_hash") @db.VarChar(255)
  role      UserRole
  status    UserStatus @default(active)
  phone     String?    @db.VarChar(20)
  avatarUrl String?    @map("avatar_url")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  brand         Brand?
  creator       Creator?
  buyer         Buyer?
  settlements   Settlement[]
  notifications Notification[]
  answeredQuestions ProductQuestion[] @relation("QuestionAnswerer")

  @@map("users")
}

// ============================================================
// BRANDS
// ============================================================

model Brand {
  id                    String    @id @default(uuid())
  userId                String    @unique @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Names
  brandName             String?   @map("brand_name")
  companyName           String?   @map("company_name")
  companyNameEn         String?   @map("company_name_en")
  companyNameJp         String?   @map("company_name_jp")
  representativeName    String?   @map("representative_name") @db.VarChar(100)
  // Info
  businessNumber        String?   @map("business_number") @db.VarChar(50)
  businessRegistrationUrl String? @map("business_registration_url")
  logoUrl               String?   @map("logo_url")
  description           String?
  descriptionEn         String?   @map("description_en")
  descriptionJp         String?   @map("description_jp")
  contactEmail          String?   @map("contact_email") @db.VarChar(255)
  contactPhone          String?   @map("contact_phone") @db.VarChar(20)
  // Commission
  platformFeeRate       Decimal   @default(0.03) @map("platform_fee_rate") @db.Decimal(5, 4)
  creatorCommissionRate Int?      @default(25) @map("creator_commission_rate")
  enableTieredCommission Boolean  @default(false) @map("enable_tiered_commission")
  tier1Rate             Int?      @map("tier1_rate")
  tier2Rate             Int?      @map("tier2_rate")
  tier3Rate             Int?      @map("tier3_rate")
  tier4Rate             Int?      @map("tier4_rate")
  // Shipping
  shippingCountries     String[]  @default([]) @map("shipping_countries")
  defaultShippingFee    Decimal   @default(0) @map("default_shipping_fee") @db.Decimal(10, 0)
  freeShippingThreshold Decimal?  @map("free_shipping_threshold") @db.Decimal(10, 0)
  defaultCourier        String?   @map("default_courier") @db.VarChar(20)
  returnAddress         String?   @map("return_address")
  exchangePolicy        String?   @map("exchange_policy")
  // Certifications
  certifications        Json      @default("[]") @db.JsonB
  // MoCRA
  mocraStatus           MocraStatus @default(green) @map("mocra_status")
  usSalesYtd            Decimal   @default(0) @map("us_sales_ytd")
  jpSalesYtd            Decimal   @default(0) @map("jp_sales_ytd")
  monthlyFee            Int       @default(55000) @map("monthly_fee")
  // Bank
  bankName              String?   @map("bank_name")
  bankAccount           String?   @map("bank_account")
  accountNumber         String?   @map("account_number")
  accountHolder         String?   @map("account_holder")
  bankHolder            String?   @map("bank_holder") @db.VarChar(50)
  bankCode              String?   @map("bank_code")
  bankVerified          Boolean   @default(false) @map("bank_verified")
  bankVerifiedAt        DateTime? @map("bank_verified_at") @db.Timestamptz
  // Settlement
  settlementCycle       String    @default("monthly") @map("settlement_cycle")
  minimumPayout         Int       @default(50) @map("minimum_payout")
  // Approval
  approved              Boolean   @default(false)
  approvedAt            DateTime? @map("approved_at") @db.Timestamptz
  // Brand lines
  brandLines            Json      @default("[]") @map("brand_lines") @db.JsonB
  // Timestamps
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Instagram 연동 (DM 발송용)
  brandInstagramHandle              String?           @map("brand_instagram_handle")
  brandInstagramHandleStatus        BrandIgHandleStatus @default(NOT_LINKED) @map("brand_instagram_handle_status")
  brandInstagramHandleVerifiedAt    DateTime?         @map("brand_instagram_handle_verified_at") @db.Timestamptz
  brandInstagramSessionExpiresAt    DateTime?         @map("brand_instagram_session_expires_at") @db.Timestamptz
  brandInstagramLastUsedAt          DateTime?         @map("brand_instagram_last_used_at") @db.Timestamptz
  brandInstagramDailySentCount      Int               @default(0) @map("brand_instagram_daily_sent_count")

  products              Product[]
  campaigns             Campaign[]
  orders                Order[]
  supportTickets        SupportTicket[]
  sampleRequests        SampleRequest[]
  creatorProposals      CreatorProposal[]
  creatorGroups         CreatorGroup[]
  proposalTemplates     ProposalTemplate[]
  subscription          BrandSubscription?
  messageCredits        MessageCredit[]
  subscriptionPayments  SubscriptionPayment[]
  dmQueues              DmSendQueue[]
  filterPresets         CreatorFilterPreset[]

  @@index([approved])
  @@index([mocraStatus])
  @@map("brands")
}

// ============================================================
// CREATORS
// ============================================================

model Creator {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Identity (from both migration 001 and 002)
  username             String?   @unique
  shopId               String?   @unique @map("shop_id") @db.VarChar(50)
  displayName          String?   @map("display_name") @db.VarChar(50)
  bio                  String?
  bioEn                String?   @map("bio_en")
  bioJp                String?   @map("bio_jp")
  // Images
  profileImage         String?   @map("profile_image")
  profileImageUrl      String?   @map("profile_image_url")
  coverImageUrl        String?   @map("cover_image_url")
  bannerImageUrl       String?   @map("banner_image_url")
  bannerLink           String?   @map("banner_link")
  // Social handles
  instagramHandle      String?   @map("instagram_handle") @db.VarChar(100)
  youtubeHandle        String?   @map("youtube_handle") @db.VarChar(100)
  tiktokHandle         String?   @map("tiktok_handle") @db.VarChar(100)
  instagram            String?
  youtube              String?
  tiktok               String?
  socialLinks          Json      @default("{}") @map("social_links") @db.JsonB
  // Beauty persona
  skinType             String?   @map("skin_type") @db.VarChar(20)
  personalColor        String?   @map("personal_color") @db.VarChar(20)
  skinConcerns         String[]  @default([]) @map("skin_concerns")
  scalpConcerns        String[]  @default([]) @map("scalp_concerns")
  ageRange             String?   @map("age_range") @db.VarChar(20)
  interests            String[]  @default([])
  // Onboarding
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  onboardingStatus     String    @default("PENDING") @map("onboarding_status") @db.VarChar(20)
  categories           String[]  @default([])
  snsChannels          Json?     @map("sns_channels") @db.JsonB
  sellingExperience    Boolean?  @map("selling_experience")
  avgRevenue           String?   @map("avg_revenue") @db.VarChar(30)
  // Stats
  totalSales           Decimal   @default(0) @map("total_sales") @db.Decimal(12, 0)
  totalEarnings        Decimal   @default(0) @map("total_earnings") @db.Decimal(12, 0)
  totalRevenue         Decimal   @default(0) @map("total_revenue")
  totalOrders          Int       @default(0) @map("total_orders")
  // Business
  isBusiness           Boolean   @default(false) @map("is_business")
  businessNumber       String?   @map("business_number") @db.VarChar(50)
  // Bank/Payment
  bankName             String?   @map("bank_name")
  bankAccount          String?   @map("bank_account")
  paymentMethod        String?   @default("paypal") @map("payment_method")
  paypalEmail          String?   @map("paypal_email")
  accountNumber        String?   @map("account_number")
  swiftCode            String?   @map("swift_code")
  // Contact
  email                String?
  phone                String?
  defaultShippingAddress Json? @map("default_shipping_address") @db.JsonB
  // Shop design
  themeColor           String    @default("#1a1a1a") @map("theme_color")
  backgroundColor      String    @default("#1a1a1a") @map("background_color")
  backgroundImage      String?   @map("background_image")
  textColor            String    @default("#ffffff") @map("text_color")
  shopSettings         Json      @default("{}") @map("shop_settings") @db.JsonB
  // Level system
  level                String?   @default("bronze")
  levelPoints          Int       @default(0) @map("level_points")
  levelUpdatedAt       DateTime? @map("level_updated_at") @db.Timestamptz
  // Community
  communityEnabled     Boolean   @default(false) @map("community_enabled")
  communityType        String    @default("board") @map("community_type")
  // Status
  status               String    @default("ACTIVE") @map("status") @db.VarChar(10)
  country              String?
  // Picked products
  pickedProducts       String[]  @default([]) @map("picked_products")
  // Notification settings
  notificationSettings Json?     @map("notification_settings") @db.JsonB
  // Instagram data (imported)
  igFollowers          Int?      @map("ig_followers")
  igFollowing          Int?      @map("ig_following")
  igPostsCount         Int?      @map("ig_posts_count")
  igBio                String?   @map("ig_bio")
  igCategory           String?   @map("ig_category")
  igVerified           Boolean   @default(false) @map("ig_verified")
  igExternalUrl        String?   @map("ig_external_url")
  igIsBusinessAccount  Boolean   @default(false) @map("ig_is_business_account")
  igEngagementRate     Decimal?  @map("ig_engagement_rate") @db.Decimal(5, 2)
  igDataImportedAt     DateTime? @map("ig_data_imported_at") @db.Timestamptz
  igProfileImageR2Url  String?   @map("ig_profile_image_r2_url")
  igTier               String?   @map("ig_tier") @db.VarChar(20)
  igRecentPostThumbnails Json?   @map("ig_recent_post_thumbnails") @db.JsonB
  // Instagram data (Featuring + Apify 2026-04-16)
  igUsername             String?   @unique @map("ig_username")
  igFullName             String?   @map("ig_full_name")
  igFollowersEffective   Int?      @map("ig_followers_effective")
  igLanguage             String?   @map("ig_language")
  igAvgReach             Int?      @map("ig_avg_reach")
  igAvgLikes             Int?      @map("ig_avg_likes")
  igAvgVideoViews        Int?      @map("ig_avg_video_views")
  igAvgVideoLikes        Int?      @map("ig_avg_video_likes")
  igAvgComments          Int?      @map("ig_avg_comments")
  igAudienceGender       String?   @map("ig_audience_gender")
  igAudienceAge          String?   @map("ig_audience_age")
  igEstimatedCPR         Int?      @map("ig_estimated_cpr")
  igEstimatedAdCost      Int?      @map("ig_estimated_ad_cost")
  igProfilePicUrl        String?   @map("ig_profile_pic_url")
  igEmail                String?   @map("ig_email")
  igLastUploadDate       String?   @map("ig_last_upload_date")
  igDataSource           String?   @map("ig_data_source")
  // Instagram 상세 지표 (Phase 2)
  igAvgFeedLikes         Int?      @map("ig_avg_feed_likes")
  igAvgFeedComments      Int?      @map("ig_avg_feed_comments")
  igAvgReelViews         Int?      @map("ig_avg_reel_views")
  igAvgReelLikes         Int?      @map("ig_avg_reel_likes")
  igEstimatedReach       Int?      @map("ig_estimated_reach")
  igValidFollowers       Int?      @map("ig_valid_followers")
  igPrimaryLanguage      String?   @map("ig_primary_language")
  igLastPostAt           DateTime? @map("ig_last_post_at") @db.Timestamptz
  igEstimatedCPRDecimal  Decimal?  @map("ig_estimated_cpr_decimal") @db.Decimal(10, 2)
  igEstimatedAdFee       Decimal?  @map("ig_estimated_ad_fee") @db.Decimal(12, 0)
  audienceGenderRatio    Json?     @map("audience_gender_ratio") @db.JsonB
  audienceAgeRatio       Json?     @map("audience_age_ratio") @db.JsonB
  igLastSyncedAt         DateTime? @map("ig_last_synced_at") @db.Timestamptz
  igSyncStatus           IgSyncStatus @default(PENDING) @map("ig_sync_status")
  igHistoricalStats      Json?     @map("ig_historical_stats") @db.JsonB
  // 연락처 & 발송 가능 채널
  hasBrandEmail          Boolean   @default(false) @map("has_brand_email")
  brandContactEmail      String?   @map("brand_contact_email")
  hasPhone               Boolean   @default(false) @map("has_phone")
  phoneForAlimtalk       String?   @map("phone_for_alimtalk")
  cnecJoinStatus         CreatorCnecJoinStatus @default(NOT_JOINED) @map("cnec_join_status")
  // Timestamps
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  shopItems            CreatorShopItem[]
  collections          Collection[]
  routines             BeautyRoutine[]
  orders               Order[]
  conversions          Conversion[]
  settlements          Settlement[]
  shopVisits           ShopVisit[]
  points               CreatorPoint[]
  referralsGiven       CreatorReferral[] @relation("Referrer")
  referralsReceived    CreatorReferral[] @relation("Referred")
  grade                CreatorGrade?
  missions             CreatorMission[]
  banners              Banner[]
  creatorProducts      CreatorProduct[]
  shortUrls            ShortUrl[]
  liveSessions         LiveSession[]
  liveBotSetting       LiveBotSetting?
  levelHistory         CreatorLevelHistory[]
  mallSubscriptions    MallSubscription[]
  communityPosts       CommunityPost[]
  sampleRequests       SampleRequest[]
  buyerWishlists       BuyerWishlist[]
  buyerCarts           BuyerCart[]
  productContents      CreatorProductContent[]
  receivedProposals    CreatorProposal[]
  groupMemberships     CreatorGroupMember[]
  campaignParticipations CampaignParticipation[]
  messageCredits       MessageCredit[]
  dmQueues             DmSendQueue[]

  @@index([country])
  @@index([igFollowers])
  @@index([igCategory])
  @@index([igTier])
  @@map("creators")
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id                    String         @id @default(uuid())
  brandId               String         @map("brand_id")
  brand                 Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  // Names (multi-lang)
  name                  String?        @db.VarChar(200)
  nameKo                String?        @map("name_ko")
  nameEn                String?        @map("name_en")
  nameJp                String?        @map("name_jp")
  sku                   String?
  // Prices
  price                 Decimal?
  originalPrice         Decimal?       @map("original_price") @db.Decimal(10, 0)
  salePrice             Decimal?       @map("sale_price") @db.Decimal(10, 0)
  priceUsd              Int?           @map("price_usd")
  priceJpy              Int?           @map("price_jpy")
  originalPriceUsd      Int?           @map("original_price_usd")
  originalPriceJpy      Int?           @map("original_price_jpy")
  // Stock
  stock                 Int            @default(0)
  // Description (multi-lang)
  description           String?
  descriptionKo         String?        @map("description_ko")
  descriptionEn         String?        @map("description_en")
  descriptionJp         String?        @map("description_jp")
  // Media
  images                String[]       @default([])
  imageUrl              String?        @map("image_url")
  thumbnailUrl          String?        @map("thumbnail_url")
  // Details
  category              String?        @db.VarChar(20)
  volume                String?        @db.VarChar(100)
  ingredients           String?
  howToUse              String?        @map("how_to_use")
  usageInfo             String?        @map("usage_info")
  // Flags
  isCosmetic            Boolean        @default(false) @map("is_cosmetic")
  isActive              Boolean        @default(true) @map("is_active")
  status                String         @default("ACTIVE") @db.VarChar(10)
  allowCreatorPick      Boolean        @default(true) @map("allow_creator_pick")
  allowTrial            Boolean        @default(true) @map("allow_trial")
  defaultCommissionRate Decimal        @default(0.10) @map("default_commission_rate") @db.Decimal(5, 4)
  // Shipping
  shippingFeeType       ShippingFeeType @default(FREE) @map("shipping_fee_type")
  shippingFee           Decimal        @default(0) @map("shipping_fee") @db.Decimal(10, 0)
  freeShippingThreshold Decimal?       @map("free_shipping_threshold") @db.Decimal(10, 0)
  courier               String?        @db.VarChar(20)
  shippingInfo          String?        @map("shipping_info")
  returnPolicy          String?        @map("return_policy")
  // External detail page
  detailUrl             String?        @map("detail_url")
  // Timestamps
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  shopItems          CreatorShopItem[]
  campaignProducts   CampaignProduct[]
  orderItems         OrderItem[]
  creatorProducts    CreatorProduct[]
  liveProducts       LiveProduct[]
  productQuestions   ProductQuestion[]
  productReviews     ProductReview[]
  sampleRequests     SampleRequest[]
  buyerWishlists     BuyerWishlist[]
  buyerCarts         BuyerCart[]
  liveChatMessages   LiveChatMessage[]
  creatorContents    CreatorProductContent[]
  priceData          ProductPriceData[]
  priceBadge         PriceBadge?
  aiGonguTips        AiGonguTip[]

  @@index([isActive])
  @@index([status])
  @@map("products")
}

// ============================================================
// CREATOR PRODUCTS (legacy pick table from migration 001)
// ============================================================

model CreatorProduct {
  id           String   @id @default(uuid())
  creatorId    String   @map("creator_id")
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  productId    String   @map("product_id")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  displayOrder Int      @default(0) @map("display_order")
  isFeatured   Boolean  @default(false) @map("is_featured")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([creatorId, productId])
  @@map("creator_products")
}

// ============================================================
// CREATOR PRODUCT CONTENT (reels, shorts, etc.)
// ============================================================

model CreatorProductContent {
  id          String   @id @default(cuid())
  creatorId   String   @map("creator_id")
  productId   String   @map("product_id")
  type        String   @default("INSTAGRAM_REEL") @db.VarChar(30)
  url         String
  embedUrl    String?  @map("embed_url")
  caption     String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([creatorId, productId, url])
  @@map("creator_product_contents")
}

// ============================================================
// CAMPAIGNS
// ============================================================

model Campaign {
  id               String         @id @default(uuid())
  brandId          String         @map("brand_id")
  brand            Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  type             CampaignType
  title            String         @db.VarChar(200)
  description      String?
  status           CampaignStatus @default(DRAFT)
  startAt          DateTime?      @map("start_at") @db.Timestamptz
  endAt            DateTime?      @map("end_at") @db.Timestamptz
  recruitmentType  String         @default("OPEN") @map("recruitment_type") @db.VarChar(10)
  commissionRate   Decimal        @default(0.10) @map("commission_rate") @db.Decimal(5, 4)
  totalStock       Int?           @map("total_stock")
  soldCount        Int            @default(0) @map("sold_count")
  targetParticipants Int?         @map("target_participants")
  conditions       String?
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  products       CampaignProduct[]
  participations CampaignParticipation[]
  shopItems      CreatorShopItem[]
  promotionKit   PromotionKit?
  proposals      CreatorProposal[]

  @@index([status])
  @@index([type])
  @@map("campaigns")
}

// ============================================================
// CAMPAIGN PRODUCTS
// ============================================================

model CampaignProduct {
  id              String   @id @default(uuid())
  campaignId      String   @map("campaign_id")
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId       String   @map("product_id")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  campaignPrice   Decimal  @map("campaign_price") @db.Decimal(10, 0)
  perCreatorLimit Int?     @map("per_creator_limit")

  @@map("campaign_products")
}

// ============================================================
// CAMPAIGN PARTICIPATIONS
// ============================================================

model CampaignParticipation {
  id         String    @id @default(uuid())
  campaignId String    @map("campaign_id")
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId  String    @map("creator_id")
  creator    Creator   @relation(fields: [creatorId], references: [id])
  status     String    @default("PENDING") @db.VarChar(10)
  message    String?
  appliedAt  DateTime  @default(now()) @map("applied_at") @db.Timestamptz
  approvedAt DateTime? @map("approved_at") @db.Timestamptz

  @@unique([campaignId, creatorId])
  @@map("campaign_participations")
}

// ============================================================
// COLLECTIONS
// ============================================================

model Collection {
  id           String   @id @default(uuid())
  creatorId    String   @map("creator_id")
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name         String   @db.VarChar(50)
  description  String?
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  items CreatorShopItem[]

  @@map("collections")
}

// ============================================================
// CREATOR SHOP ITEMS
// ============================================================

model CreatorShopItem {
  id           String      @id @default(uuid())
  creatorId    String      @map("creator_id")
  creator      Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  productId    String      @map("product_id")
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  campaignId   String?     @map("campaign_id")
  campaign     Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  type         String      @db.VarChar(10) // 'GONGGU' | 'PICK'
  collectionId String?     @map("collection_id")
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  displayOrder Int         @default(0) @map("display_order")
  isVisible    Boolean     @default(true) @map("is_visible")
  addedAt      DateTime    @default(now()) @map("added_at") @db.Timestamptz
  reelsUrl     String?     @map("reels_url")
  reelsCaption String?     @map("reels_caption")

  @@index([type])
  @@map("creator_shop_items")
}

// ============================================================
// BEAUTY ROUTINES
// ============================================================

model BeautyRoutine {
  id           String   @id @default(uuid())
  creatorId    String   @map("creator_id")
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  name         String   @db.VarChar(50)
  steps        Json     @default("[]") @db.JsonB
  isVisible    Boolean  @default(true) @map("is_visible")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  routineSteps RoutineStep[]

  @@map("beauty_routines")
}

// ============================================================
// ROUTINE STEPS (normalized from v1.1)
// ============================================================

model RoutineStep {
  id              String @id @default(uuid())
  routineId       String @map("routine_id")
  routine         BeautyRoutine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  stepName        String @map("step_name") @db.VarChar(50)
  stepDescription String @map("step_description")
  imageUrl        String? @map("image_url")
  linkUrl         String? @map("link_url")
  productTags     Json    @default("[]") @map("product_tags") @db.JsonB
  displayOrder    Int     @default(0) @map("display_order")

  @@map("routine_steps")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(uuid())
  orderNumber     String?     @unique @map("order_number") @db.VarChar(20)
  // Parties
  creatorId       String?     @map("creator_id")
  creator         Creator?    @relation(fields: [creatorId], references: [id])
  brandId         String?     @map("brand_id")
  brand           Brand?      @relation(fields: [brandId], references: [id])
  buyerId         String?     @map("buyer_id")
  buyer           Buyer?      @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  // Customer info (from migration 001)
  customerEmail   String?     @map("customer_email")
  customerName    String?     @map("customer_name")
  customerPhone   String?     @map("customer_phone")
  // Buyer info (from migration 002)
  buyerName       String?     @map("buyer_name") @db.VarChar(100)
  buyerPhone      String?     @map("buyer_phone") @db.VarChar(30)
  buyerEmail      String?     @map("buyer_email") @db.VarChar(200)
  // Shipping
  shippingAddress String?     @map("shipping_address")
  shippingDetail  String?     @map("shipping_detail")
  shippingZipcode String?     @map("shipping_zipcode") @db.VarChar(20)
  shippingMemo    String?     @map("shipping_memo")
  shippingFee     Decimal     @default(0) @map("shipping_fee") @db.Decimal(12, 0)
  // Amounts
  subtotal        Decimal?
  productAmount   Decimal?    @map("product_amount") @db.Decimal(10, 0)
  totalAmount     Decimal     @map("total_amount")
  // Revenue split (from migration 001)
  creatorRevenue  Decimal?    @map("creator_revenue")
  platformRevenue Decimal?    @map("platform_revenue")
  brandRevenue    Decimal?    @map("brand_revenue")
  // Location
  country         String?
  currency        String?
  // Status
  status          String      @default("PAID")
  // Payment
  paymentMethod   String?     @map("payment_method") @db.VarChar(50)
  paymentKey      String?     @map("payment_key") @db.VarChar(100)
  paymentIntentId String?     @map("payment_intent_id")
  pgTransactionId String?     @map("pg_transaction_id") @db.VarChar(200)
  pgProvider      String?     @map("pg_provider") @db.VarChar(50)
  // Tracking
  trackingNumber  String?     @map("tracking_number") @db.VarChar(100)
  courierCode     String?     @map("courier_code") @db.VarChar(20)
  notes           String?
  // Timestamps
  paidAt          DateTime?   @map("paid_at") @db.Timestamptz
  shippedAt       DateTime?   @map("shipped_at") @db.Timestamptz
  deliveredAt     DateTime?   @map("delivered_at") @db.Timestamptz
  confirmedAt     DateTime?   @map("confirmed_at") @db.Timestamptz
  completedAt     DateTime?   @map("completed_at") @db.Timestamptz
  cancelledAt     DateTime?   @map("cancelled_at") @db.Timestamptz
  cancelReason    String?     @map("cancel_reason")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  items       OrderItem[]
  conversions Conversion[]
  reviews     ProductReview[]

  @@index([status])
  @@index([country])
  @@index([createdAt])
  @@map("orders")
}

// ============================================================
// ORDER ITEMS
// ============================================================

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String   @map("product_id")
  product      Product  @relation(fields: [productId], references: [id])
  campaignId   String?  @map("campaign_id")
  productName  String?  @map("product_name") @db.VarChar(200)
  productImage String?  @map("product_image")
  quantity     Int      @default(1)
  unitPrice    Decimal  @map("unit_price")
  totalPrice   Decimal  @map("total_price")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversions Conversion[]

  @@map("order_items")
}

// ============================================================
// CONVERSIONS
// ============================================================

model Conversion {
  id               String   @id @default(uuid())
  orderId          String   @map("order_id")
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId      String   @map("order_item_id")
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  creatorId        String   @map("creator_id")
  creator          Creator  @relation(fields: [creatorId], references: [id])
  conversionType   String   @map("conversion_type") @db.VarChar(10)
  orderAmount      Decimal  @map("order_amount") @db.Decimal(10, 0)
  commissionRate   Decimal  @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(10, 0)
  status           String   @default("PENDING") @db.VarChar(10)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  confirmedAt      DateTime? @map("confirmed_at") @db.Timestamptz

  @@map("conversions")
}

// ============================================================
// SETTLEMENTS
// ============================================================

model Settlement {
  id                 String    @id @default(uuid())
  userId             String?   @map("user_id")
  user               User?     @relation(fields: [userId], references: [id])
  userRole           String?   @map("user_role")
  creatorId          String?   @map("creator_id")
  creator            Creator?  @relation(fields: [creatorId], references: [id])
  period             String?
  periodStart        DateTime? @map("period_start") @db.Date
  periodEnd          DateTime? @map("period_end") @db.Date
  // Amounts (from migration 002 format)
  totalConversions   Int       @default(0) @map("total_conversions")
  totalSales         Decimal   @default(0) @map("total_sales") @db.Decimal(12, 0)
  directCommission   Decimal   @default(0) @map("direct_commission") @db.Decimal(10, 0)
  indirectCommission Decimal   @default(0) @map("indirect_commission") @db.Decimal(10, 0)
  grossCommission    Decimal   @default(0) @map("gross_commission") @db.Decimal(10, 0)
  withholdingTax     Decimal   @default(0) @map("withholding_tax") @db.Decimal(10, 0)
  netAmount          Decimal   @default(0) @map("net_amount") @db.Decimal(10, 0)
  // From migration 001 format
  totalRevenue       Decimal?  @map("total_revenue")
  currency           String?
  details            Json?     @default("{}") @db.JsonB
  // Status
  status             String    @default("PENDING") @db.VarChar(15)
  paidAt             DateTime? @map("paid_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([status])
  @@map("settlements")
}

// ============================================================
// SHOP VISITS
// ============================================================

model ShopVisit {
  id              String   @id @default(uuid())
  creatorId       String   @map("creator_id")
  creator         Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  visitorId       String   @map("visitor_id") @db.VarChar(100)
  ipAddress       String?  @map("ip_address") @db.VarChar(45)
  userAgent       String?  @map("user_agent")
  referer         String?
  attributionData Json     @default("{}") @map("attribution_data") @db.JsonB
  visitedAt       DateTime @default(now()) @map("visited_at") @db.Timestamptz
  expiresAt       DateTime @map("expires_at") @db.Timestamptz

  @@map("shop_visits")
}

