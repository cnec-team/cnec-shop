{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cnecshop.com" }],
      "destination": "https://www.cnecshop.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/price-update",
      "schedule": "0 3 * * *"
    }
  ]
}
