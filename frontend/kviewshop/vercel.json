{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cnecshop.com" }],
      "destination": "https://www.cnecshop.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/price-update",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-creators",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/pricing-daily",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/pricing-monthly-reset",
      "schedule": "0 15 1 * *"
    },
    {
      "path": "/api/cron/shipping-delay",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/dormant-warning",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/dormant-transition",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/cart-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/coupon-expiry",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/repurchase-reminder",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/low-stock-check",
      "schedule": "15 * * * *"
    }
  ]
}
